# ─────────────────────────────────────────────────
#  HeyTaxi - Environment Configuration
#  RENAME this file to .env before running docker-compose
#  NEVER commit .env to git!
# ─────────────────────────────────────────────────

# Gmail SMTP (for OTP emails - FREE)
# Step 1: Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
# Step 2: Generate password for "Mail" → copy the 16-char password below
GMAIL_USERNAME=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# JWT Secret - Use a strong random string (min 32 chars)
JWT_SECRET=your_jwt_secret

# PostgreSQL (Docker container uses these)
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=db_password


# ─── API ──────────────────────────────────────────────────────────────────────
VITE_API_URL=/api

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Get your key from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Places API, Directions API, Distance Matrix API
VITE_GOOGLE_MAPS_KEY=your_google_maps_key

# ─── Razorpay (Test Mode) ─────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys (test mode)
VITE_RAZORPAY_KEY_ID=your_razorpay_key

